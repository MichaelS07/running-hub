---
import Base from "../layouts/Base.astro";
import ShoeCard from "../components/ShoeCard.astro";
import { getShoes, shoesByArchetype } from "../lib/shoes.js";
import { getRaces } from "../lib/races.js";
const total = getShoes().length;
const raceCount = getRaces().length;
// "best in each category" — the #1 ranked shoe per archetype
const featured = shoesByArchetype().map((c) => c.shoes[0]).filter(Boolean);
---
<Base title="RunHub — Every running shoe, scored">
  <section class="hero">
    <div class="wrap">
      <h1>Every running shoe, <em>scored</em>.</h1>
      <p class="lede">RunHub rates every running shoe <strong>within its own category</strong> on six criteria — ride, cushioning, weight, fit, durability and expert reviews — then ranks them. No marketing fluff, no paid placement. Just one transparent score so you can find the right shoe fast.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/shoes/">Browse all shoes →</a>
        <a class="btn btn-ghost" href="/how-we-score/">How we score</a>
      </div>
      <div class="hero-stats">
        <div class="hstat"><b>{total}</b><span>shoes scored</span></div>
        <div class="hstat"><b>6</b><span>criteria per shoe</span></div>
        <div class="hstat"><b>{raceCount}</b><span>races listed</span></div>
        <div class="hstat"><b>$0</b><span>paid placement</span></div>
      </div>
    </div>
  </section>

  <main class="wrap">
    <section class="block">
      <h2 class="block-title">How it works</h2>
      <div class="steps">
        <div class="step">
          <div class="n">01</div>
          <h3>We gather the data</h3>
          <p>Lab-measured specs and expert reviews for every shoe — weight, stack, ride, energy return and more.</p>
        </div>
        <div class="step">
          <div class="n">02</div>
          <h3>We score within category</h3>
          <p>A racer is judged against racers, a trainer against trainers. Six weighted criteria, one 0–100 score.</p>
        </div>
        <div class="step">
          <div class="n">03</div>
          <h3>You get a straight answer</h3>
          <p>Ranked lists and a value rating, so you can see what's actually worth your money — and why.</p>
        </div>
      </div>
    </section>

    <section class="block">
      <div class="section-head">
        <h2 class="block-title">Top rated right now</h2>
        <a href="/shoes/">See all {total} shoes →</a>
      </div>
      <div class="grid">
        {featured.map((shoe) => <ShoeCard shoe={shoe} />)}
      </div>
    </section>

    <section class="block split-band">
      <a class="split-card" href="/races/">
        <h2 class="block-title">Find a run near you</h2>
        <p>{raceCount} free weekly parkruns across New Zealand and Australia, by region. Just turn up.</p>
        <span class="split-link">Browse races →</span>
      </a>
      <a class="split-card" href="/guides/">
        <h2 class="block-title">Read the data studies</h2>
        <p>Does price buy quality? What does a carbon plate really get you? We ran the numbers on our own database.</p>
        <span class="split-link">Read the guides →</span>
      </a>
    </section>
  </main>
</Base>
