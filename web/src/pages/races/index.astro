---
import Base from "../../layouts/Base.astro";
import { regionsByCountry, getRaces, slugify } from "../../lib/races.js";
const groups = regionsByCountry();
const total = getRaces().length;
---
<Base title="Find a run near you — parkruns across NZ & Australia — RunHub" description="Every parkrun in New Zealand and Australia by region — free, weekly, timed 5km runs open to everyone. Find your local one.">
  <section class="hero">
    <div class="wrap">
      <h1>Find a run <em>near you</em>.</h1>
      <p class="lede">Start with <strong>parkrun</strong> — free, weekly, timed 5km runs open to absolutely everyone, from first-timers to club racers. {total} of them across New Zealand and Australia. Pick your region.</p>
    </div>
  </section>

  <main class="wrap">
    {groups.map((g) => (
      <section class="block">
        <h2 class="block-title">{g.country}</h2>
        <div class="region-grid">
          {g.regions.map((r) => (
            <a class="region-chip" href={`/races/${r.slug}/`}>
              <span class="region-name">{r.name}</span>
              <span class="region-count">{r.count}</span>
            </a>
          ))}
        </div>
      </section>
    ))}

    <section class="cta-band" style="margin-top:40px">
      <div>
        <h2 class="block-title">Marathons, halves & trail races — coming next</h2>
        <p>We're starting with parkrun because it's free, weekly and everywhere. Next: organised races with dates and entry links, listed under these same regions.</p>
      </div>
    </section>
  </main>
</Base>
