---
import Base from "../../layouts/Base.astro";
import { allRegions, racesByRegionSlug } from "../../lib/races.js";

export function getStaticPaths() {
  return allRegions().map((reg) => ({
    params: { region: reg.slug },
    props: { reg, races: racesByRegionSlug(reg.slug).sort((a, b) => a.name.localeCompare(b.name)) },
  }));
}

const { reg, races } = Astro.props;
---
<Base
  title={`parkruns in ${reg.name} — free weekly 5km runs — RunHub`}
  description={`Every parkrun in ${reg.name}, ${reg.country} — ${races.length} free, weekly, timed 5km runs. Find your local one by town or park.`}
>
  <div class="wrap page-head">
    <p class="crumbs"><a href="/races/">Races</a> &nbsp;/&nbsp; {reg.country}</p>
    <h1>parkruns in {reg.name}</h1>
    <p>{races.length} free, weekly, timed 5km runs across {reg.name}. Just turn up — all paces welcome.</p>
  </div>

  <main class="wrap">
    <input type="search" id="race-search" class="race-search" placeholder="Search by town, park or name…" autocomplete="off" aria-label="Search races" />
    <p class="race-count"><b data-race-count>{races.length}</b> runs</p>
    <div class="race-list" data-race-list>
      {races.map((r) => (
        <a class="race-row" href={r.url} target="_blank" rel="noopener" data-race data-text={`${r.name} ${r.location} ${r.city}`.toLowerCase()}>
          <div class="race-main">
            <div class="race-name">{r.name}</div>
            <div class="race-loc">{r.location}{r.city ? ` · ${r.city}` : ""}</div>
          </div>
          <div class="race-meta">{r.day} · {r.distance} · free{r.type === "junior parkrun" ? " · kids" : ""}</div>
        </a>
      ))}
    </div>
    <p class="empty-state" data-race-empty style="display:none">No runs match — try a different town or park name.</p>
  </main>

  <script>
    const input = document.getElementById("race-search");
    const rows = Array.from(document.querySelectorAll("[data-race]"));
    const countEl = document.querySelector("[data-race-count]");
    const empty = document.querySelector("[data-race-empty]");
    input?.addEventListener("input", () => {
      const q = input.value.trim().toLowerCase();
      let n = 0;
      for (const r of rows) {
        const show = !q || r.dataset.text.includes(q);
        r.style.display = show ? "" : "none";
        if (show) n++;
      }
      if (countEl) countEl.textContent = n;
      if (empty) empty.style.display = n ? "none" : "";
    });
  </script>
</Base>
