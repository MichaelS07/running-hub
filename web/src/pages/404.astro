---
import Base from "../layouts/Base.astro";
---
<Base title="Page not found — RunHub" description="That page doesn't exist. Browse scored running shoes, races and guides instead.">
  <div class="wrap page-head" style="padding-bottom:60px">
    <h1>404 — that page ran off.</h1>
    <p>No shoe, race or guide lives at this address. Try one of these instead:</p>
    <div class="cta-row" style="margin-top:22px">
      <a class="btn btn-primary" href="/shoes/">Browse shoes</a>
      <a class="btn btn-ghost" href="/races/">Find a race</a>
      <a class="btn btn-ghost" href="/guides/">Read the guides</a>
    </div>
  </div>
</Base>
