---
import "../styles/global.css";
import { ARCH_ORDER, ARCHETYPES, CATEGORY_SLUGS } from "../lib/shoes.js";
const { title, description = "An opinionated, transparently scored database of running shoes — rated within category on weight, ride, cushioning, fit, durability and expert reviews." } = Astro.props;
const path = Astro.url.pathname;
const canonical = new URL(path, Astro.site);
const shoesActive = path.startsWith("/shoes") || path.startsWith("/categories");
const racesActive = path.startsWith("/races");
const guidesActive = path.startsWith("/guides");
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0e1116" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="RunHub" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href="/">Run<span>Hub</span></a>
        <form class="search" action="/search/" role="search">
          <input type="search" id="shoe-search" name="q" placeholder="Search shoes…" autocomplete="off" aria-label="Search shoes" />
          <div class="search-results" id="search-results"></div>
        </form>
        <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <nav class="nav" id="nav">
          <div class="nav-item has-dropdown">
            <a href="/shoes/" class={`nav-link ${shoesActive ? "active" : ""}`}>Shoes <span class="caret">▾</span></a>
            <div class="dropdown">
              <a href="/shoes/">All shoes</a>
              {ARCH_ORDER.map((k) => (
                <a href={`/categories/${CATEGORY_SLUGS[k]}/`}>{ARCHETYPES[k]}</a>
              ))}
            </div>
          </div>
          <a class={`nav-link ${racesActive ? "active" : ""}`} href="/races/">Races</a>
          <a class={`nav-link ${guidesActive ? "active" : ""}`} href="/guides/">Guides</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="wrap footer-grid">
        <div class="footer-col footer-brand-col">
          <a class="brand" href="/">Run<span>Hub</span></a>
          <p>Every running shoe scored within its category — transparent, consistent, no paid placement. <a href="/how-we-score/">How we score →</a></p>
        </div>
        <div class="footer-col">
          <h4>Shoes</h4>
          <a href="/shoes/">All shoes</a>
          {ARCH_ORDER.map((k) => <a href={`/categories/${CATEGORY_SLUGS[k]}/`}>{ARCHETYPES[k]}</a>)}
        </div>
        <div class="footer-col">
          <h4>Explore</h4>
          <a href="/races/">Find a race</a>
          <a href="/guides/">Guides</a>
          <a href="/compare/">Compare shoes</a>
          <a href="/how-we-score/">How we score</a>
        </div>
      </div>
      <div class="wrap footer-note">
        <p>Scores are computed from lab specs and expert reviews. Some outbound links may become affiliate links — they never affect a shoe's score.</p>
      </div>
    </footer>

    <script>
      // --- mobile menu ---
      const t = document.querySelector(".nav-toggle");
      const n = document.getElementById("nav");
      t?.addEventListener("click", () => {
        const open = n.classList.toggle("open");
        t.setAttribute("aria-expanded", String(open));
      });

      // --- search ---
      let _index = null;
      const loadIndex = async () => (_index ||= await (await fetch("/shoes.json")).json());
      const input = document.getElementById("shoe-search");
      const results = document.getElementById("search-results");
      input?.addEventListener("input", async () => {
        const q = input.value.trim().toLowerCase();
        if (!q) { results.innerHTML = ""; results.classList.remove("open"); return; }
        const data = await loadIndex();
        const matches = data.filter((s) => s.name.toLowerCase().includes(q) || s.brand.toLowerCase().includes(q));
        const hits = matches.slice(0, 6);
        let html = hits.length
          ? hits.map((s) => `<a href="/shoes/${s.slug}/"><img src="${s.image_url}" alt="" /><span>${s.name}</span><b>${Math.round(s.runhub_score)}</b></a>`).join("")
          : '<div class="no-hits">No matches</div>';
        if (matches.length) html += `<a class="search-all" href="/search/?q=${encodeURIComponent(input.value.trim())}">See all ${matches.length} results →</a>`;
        results.innerHTML = html;
        results.classList.add("open");
      });
      document.addEventListener("click", (e) => {
        if (!e.target.closest(".search")) results?.classList.remove("open");
      });

      // --- compare selection (persists across pages) ---
      const CKEY = "runhub-compare";
      const readSel = () => { try { return JSON.parse(localStorage.getItem(CKEY)) || []; } catch { return []; } };
      const writeSel = (a) => localStorage.setItem(CKEY, JSON.stringify(a));
      function refreshCompare() {
        const sel = readSel();
        document.querySelectorAll(".compare-btn").forEach((b) => {
          const on = sel.includes(b.dataset.slug);
          b.classList.toggle("active", on);
          b.textContent = on ? "✓ Added" : "+ Compare";
        });
        let tray = document.getElementById("compare-tray");
        if (!sel.length) { tray?.remove(); return; }
        if (!tray) { tray = document.createElement("div"); tray.id = "compare-tray"; document.body.appendChild(tray); }
        tray.innerHTML = `<span class="ct-n">${sel.length} selected</span><a class="ct-go" href="/compare/?ids=${sel.join(",")}">Compare →</a><button class="ct-clear" type="button">Clear</button>`;
        tray.querySelector(".ct-clear").onclick = () => { writeSel([]); refreshCompare(); };
      }
      document.addEventListener("click", (e) => {
        const b = e.target.closest(".compare-btn");
        if (!b) return;
        e.preventDefault();
        const sel = readSel();
        const i = sel.indexOf(b.dataset.slug);
        if (i >= 0) sel.splice(i, 1);
        else { if (sel.length >= 4) { alert("You can compare up to 4 shoes at once."); return; } sel.push(b.dataset.slug); }
        writeSel(sel);
        refreshCompare();
      });
      window.runhubRefreshCompare = refreshCompare; // let client-rendered pages re-sync
      refreshCompare();
    </script>
  </body>
</html>
